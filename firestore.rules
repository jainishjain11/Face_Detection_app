rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    match /users/{userId} {
      // Users can read/write only their own profile
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Sessions sub-collection
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── OTPs ──
    match /otps/{email} {
      // Only allow reads from authenticated users who own the email
      allow read: if request.auth != null && request.auth.token.email == email;
      // Allow creation/update only from our Cloud Functions (via admin SDK)
      // Direct writes blocked for security
      allow write: if false;
    }

    // ── Analytics ──
    match /analytics/{docId} {
      allow create: if request.auth != null;
      allow read: if false; // Admin only
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
